{
  "name": "dailyhot_api",
  "version": "1.0.5",
  "description": "一个今日热榜",
  "main": "index.js",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "lint:fix": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "syntax": "node -c index.js && node -c src/app.js && find src utils tests -name '*.js' -print0 | xargs -0 -n1 node -c",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:contract": "vitest run tests/contracts",
    "test:smoke": "node tests/smoke/live-providers.js",
    "ci": "pnpm lint && pnpm format:check && pnpm syntax && pnpm test:coverage",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "prd": "pm2 start index.js",
    "build": "node -c index.js && node -c src/app.js"
  },
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10 <12"
  },
  "author": "imsyy",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.3.4",
    "cheerio": "1.0.0-rc.12",
    "dotenv": "^16.0.3",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.3.0",
    "koa-router": "^12.0.0",
    "koa-static": "^5.0.0",
    "koa2-cors": "^2.0.6",
    "mongodb": "^6.20.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.48.0",
    "eslint-plugin-vue": "^9.17.0",
    "nodemon": "^2.0.22",
    "nock": "^13.5.6",
    "prettier": "^3.0.2",
    "vitest": "^2.1.8"
  }
}
