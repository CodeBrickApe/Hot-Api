# 服务端口
PORT=6688

# 允许跨域访问的域名，多个域名用英文逗号分隔；开发环境可用 *
ALLOWED_DOMAIN=*

# 保护 /:provider/new 强制刷新接口
ADMIN_TOKEN=replace-with-a-long-random-token

# 天气接口使用的百度地图 AK
BAIDU_MAP_AK=

# 可选：开启 MongoDB 快照、趋势和故障记录
MONGODB_URI=
MONGODB_DB=dailyhot

# 外部 API 请求治理
UPSTREAM_TIMEOUT_MS=5000
UPSTREAM_RETRIES=1
DEFAULT_PROVIDER_TTL=300
DEFAULT_PROVIDER_STALE_TTL=86400
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=10

# 可选：共享缓存。memory 适合单实例；rest 适合 Vercel / 多实例部署
CACHE_DRIVER=memory
CACHE_NAMESPACE=dailyhot
CACHE_REST_URL=
CACHE_REST_TOKEN=

# 也兼容 Vercel KV / Upstash 的默认变量名
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
